modules = ["python-3.12", "nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Services"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Celery Worker"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PYTHONPATH=. python3 -m uvicorn apps.api.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p .data/redis && redis-server --port 6379 --dir .data/redis --daemonize no --save ''"
waitForPort = 6379

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Services"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p .data/redis .data/minio && redis-server --port 6379 --dir .data/redis --daemonize no --save '' & MINIO_ROOT_USER=minioadmin MINIO_ROOT_PASSWORD=minioadmin123 minio server .data/minio --address :9000 --console-address :9001 & wait"
waitForPort = 9000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Celery Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PYTHONPATH=. python3 -m celery -A apps.worker.main.celery_app worker --loglevel=info --concurrency=2 -Q default,ai,render,publish,dlq"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pkg-config", "postgresql", "rustc", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
SI_AI_PROVIDER = "mock"
ENVIRONMENT = "development"
SECRET_KEY = "7ce88c08d708141f58ee85470424decc4b6425c6c6c1cd041ff01bf42ecc66f96446af20898e477aedf50e574878e589"
REDIS_URL = "redis://localhost:6379/0"
CELERY_BROKER_URL = "redis://localhost:6379/1"
CELERY_RESULT_BACKEND = "redis://localhost:6379/1"
MINIO_ENDPOINT = "localhost:9000"
MINIO_ACCESS_KEY = "minioadmin"
MINIO_SECRET_KEY = "minioadmin123"
MINIO_SECURE = "false"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 9000
externalPort = 9000
