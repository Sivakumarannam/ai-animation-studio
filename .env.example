# Application
APP_NAME="AI Animation Studio"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-64-chars

# Database
POSTGRES_DB=cartoon_studio
POSTGRES_USER=cartoon_user
POSTGRES_PASSWORD=cartoon_pass
DATABASE_URL=postgresql+asyncpg://cartoon_user:cartoon_pass@localhost:5432/cartoon_studio

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# CORS (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Providers (configured per environment)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
COMFYUI_BASE_URL=http://localhost:8188
PIPER_BINARY=piper
PIPER_MODELS_DIR=/models/piper
WHISPER_MODEL=base

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Plugins
ENABLED_PLUGINS=["telugu_family_comedy"]
